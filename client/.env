# Client environment variables
# Backend server URL for Socket.io connection (the /api proxy handles REST automatically via Vite)
VITE_API_URL=http://localhost:5000

# Firebase Client Config (already hardcoded in src/firebase/config.js)
# If you want to move them here:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
