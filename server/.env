PORT=5000
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Firebase Admin SDK - provide ONE of the following:
# Option 1: Paste the full service account JSON as a string (escape quotes)
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Option 2: Path to service account JSON file (relative to server/firebase/)
FIREBASE_SERVICE_ACCOUNT_PATH=../serviceAccountKey.json
