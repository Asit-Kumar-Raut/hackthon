PORT=5000
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Firebase Admin SDK - provide ONE of the following:

# Option 1: Paste the full service account JSON as a string (most portable)
# Get from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key":"...","client_email":"..."}

# Option 2: Path to service account JSON file (relative to server/)
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option 3: Default credentials (Google Cloud / Firebase emulator - no setup needed)
# If neither KEY nor PATH is set, Firebase will use Application Default Credentials

# Optional alert email credentials (used for sending notification emails)
# Use a Gmail account and corresponding app password (see https://support.google.com/accounts/answer/185833)
# Example:
# ALERT_EMAIL=ardiliumplatform@gmail.com
# ALERT_EMAIL_PASS=axztdwsbqxaajrzx   # no spaces
# (alternatively set EMAIL_USER/EMAIL_PASS instead of ALERT_*)
